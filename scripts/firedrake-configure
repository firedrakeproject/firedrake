    tuple(
        pkg
        for pkg in LINUX_APT_PACKAGES
        if pkg not in CUDA_PETSC_LINUX_APT_SKIP_PACKAGES
    )
    + CUDA_EXTRAS_LINUX_APT_PACKAGES
